{
  "name": "narralab",
  "description": "Local desktop app for structuring documentary films scene by scene.",
  "private": true,
  "version": "0.0.0",
  "author": "Vegard Lund Bergheim",
  "main": "dist-electron/app.js",
  "scripts": {
    "rebuild:electron": "node node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "predev": "npm run rebuild:electron",
    "dev": "vite",
    "predev:app": "npm run rebuild:electron",
    "dev:app": "vite",
    "prestart": "npm run rebuild:electron",
    "start": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:dir": "tsc -b && vite build && electron-builder --dir",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "node scripts/run-test-suite.mjs",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test:watch": "vitest tests/unit",
    "check": "npm run lint && npm run typecheck && npm run test",
    "preview": "vite preview",
    "postinstall": "npm run rebuild:electron"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "ffmpeg-static": "^5.2.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.2"
  },
  "build": {
    "publish": null,
    "appId": "com.narralab.desktop",
    "productName": "NarraLab",
    "copyright": "Copyright © 2026 Vegard Lund Bergheim",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "narralab",
        "name": "NarraLab Project",
        "description": "NarraLab local project file",
        "role": "Editor",
        "icon": "icon.icns"
      },
      {
        "ext": "docudoc",
        "name": "Legacy NarraLab Project",
        "description": "Legacy NarraLab local project file",
        "role": "Editor",
        "icon": "icon.icns"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "build/icon.icns"
    }
  }
}
